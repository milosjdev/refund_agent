# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Optional — override gpt-4o-mini pricing (USD per 1M tokens) if you change model
# PRICE_INPUT_PER_M=0.15
# PRICE_OUTPUT_PER_M=0.6

# Neon Postgres (Vercel → Storage → Neon will auto-inject this on deploys).
# For local dev, paste the pooled connection string from neon.tech here.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/dbname?sslmode=require
